# Ensure shell scripts and Unix config files always use LF line endings
*.sh text eol=lf
*.env text eol=lf
.xcode.env text eol=lf
.xcode.env.local text eol=lf

# React Native / Expo
*.gradle text eol=lf
gradlew text eol=lf
*.pbxproj text eol=lf
*.xcconfig text eol=lf
*.xcscheme text eol=lf
*.storyboard text eol=lf
*.xcworkspacedata text eol=lf

# Standard text files
*.json text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
